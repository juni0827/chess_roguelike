<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_upgrade_card"
        android:layout_margin="8dp"
        android:padding="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvRoundInfo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="라운드 1/5"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="점수: 0"
                android:textSize="14sp"
                android:textColor="@color/text_primary" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/progressRun"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="8dp"
            android:max="5"
            android:progress="1"
            android:progressTint="@color/valid_move_highlight"
            android:progressBackgroundTint="@color/surface_variant" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/tvTurnStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="플레이어 턴"
                android:textSize="13sp"
                android:textColor="@color/valid_move_highlight"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvThreatLevel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="위협도: 낮음"
                android:textSize="13sp"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvObjective"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="목표: 적 킹을 체크메이트하고 생존하기"
            android:textSize="12sp"
            android:textColor="@color/text_secondary" />
    </LinearLayout>

    <com.chessroguelike.ui.BoardView
        android:id="@+id/boardView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bottom_panel_bg"
        android:padding="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvPlayerPieces"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="13sp"
                android:textColor="@color/player_piece_color" />

            <TextView
                android:id="@+id/tvCaptured"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="포획: 0"
                android:textSize="13sp"
                android:textColor="@color/ability_gold" />

            <TextView
                android:id="@+id/tvEnemyPieces"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="13sp"
                android:textColor="@color/enemy_piece_color"
                android:gravity="end" />
        </LinearLayout>

        <Button
            android:id="@+id/btnSkipDoubleMove"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:text="이중 이동 건너뛰기"
            android:textSize="13sp"
            android:background="@drawable/bg_button"
            android:textColor="@android:color/white"
            android:visibility="gone"
            android:layout_marginBottom="6dp" />

        <Button
            android:id="@+id/btnEndGame"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:text="게임 종료"
            android:textSize="13sp"
            android:backgroundTint="@color/enemy_piece_color"
            android:textColor="@android:color/white" />
    </LinearLayout>
</LinearLayout>
