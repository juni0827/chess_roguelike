<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Status bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="@color/status_bar_bg">

        <TextView
            android:id="@+id/tvRoundInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="라운드 1/5"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvTurnStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="플레이어 턴"
            android:textSize="14sp"
            android:textColor="@color/valid_move_highlight"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvScore"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="점수: 0"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:gravity="end" />
    </LinearLayout>

    <!-- Board -->
    <com.chessroguelike.ui.BoardView
        android:id="@+id/boardView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Bottom panel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bottom_panel_bg"
        android:padding="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/tvPlayerPieces"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="내 기물: 16개"
                android:textSize="13sp"
                android:textColor="@color/player_piece_color" />

            <TextView
                android:id="@+id/tvEnemyPieces"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="적 기물: 16개"
                android:textSize="13sp"
                android:textColor="@color/enemy_piece_color"
                android:gravity="end" />
        </LinearLayout>

        <Button
            android:id="@+id/btnSkipDoubleMove"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="이중 이동 건너뛰기"
            android:textSize="13sp"
            android:background="@drawable/bg_button"
            android:textColor="@android:color/white"
            android:visibility="gone"
            android:layout_marginBottom="4dp" />

        <Button
            android:id="@+id/btnEndGame"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="게임 종료"
            android:textSize="13sp"
            android:backgroundTint="@color/enemy_piece_color"
            android:textColor="@android:color/white" />
    </LinearLayout>
</LinearLayout>
