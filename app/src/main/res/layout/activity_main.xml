<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="@color/background">

    <TextView
        android:id="@+id/tvGameTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="36sp"
        android:textColor="@color/text_primary"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="♔ ♕ ♖ ♗ ♘ ♙"
        android:textSize="28sp"
        android:textColor="@color/player_piece_color"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="♚ ♛ ♜ ♝ ♞ ♟"
        android:textSize="28sp"
        android:textColor="@color/enemy_piece_color"
        android:layout_marginBottom="48dp" />

    <Button
        android:id="@+id/btnStartGame"
        android:layout_width="240dp"
        android:layout_height="56dp"
        android:textSize="18sp"
        android:textStyle="bold"
        android:background="@drawable/bg_button"
        android:textColor="@android:color/white"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnContinueGame"
        android:layout_width="240dp"
        android:layout_height="56dp"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="@drawable/bg_button"
        android:textColor="@android:color/white"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnImportMod"
        android:layout_width="240dp"
        android:layout_height="48dp"
        android:textSize="14sp"
        android:background="@drawable/bg_button"
        android:textColor="@android:color/white"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnLanguage"
        android:layout_width="240dp"
        android:layout_height="48dp"
        android:textSize="14sp"
        android:background="@drawable/bg_button"
        android:textColor="@android:color/white"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tvProfileSummary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:layout_marginBottom="6dp" />

    <TextView
        android:id="@+id/tvModSummary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/tvLocaleSummary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/tvRunSummary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/enemy_piece_color"
        android:textSize="13sp"
        android:gravity="center"
        android:layout_marginBottom="20dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_upgrade_card"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"
                android:id="@+id/tvRulesTitle" />

            <TextView
                android:id="@+id/tvRulesContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:lineSpacingMultiplier="1.4" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
